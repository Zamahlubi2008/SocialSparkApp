<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFF3E0">


 <TextView
     android:id="@+id/title"
     android:layout_width="wrap_content"
     android:layout_height="wrap_content"
     android:text="@string/social_spark"
     android:textSize="24sp"
     android:textStyle="bold"
     android:textColor="#E65100"
     android:layout_marginBottom="20dp"/>

 <EditText
     android:id="@+id/timeInput"
     android:layout_width="416dp"
     android:layout_height="wrap_content"
     android:autofillHints="Enter time of day"
     android:hint="@string/enter_time_of_day_morning_afternoon"
     android:backgroundTint="#FF9800"/>

 <Button
     android:id="@+id/suggestButton"
     android:layout_width="match_parent"
     android:layout_height="wrap_content"
     android:backgroundTint="#FFFFFF"
     android:layout_marginTop="10dp"
     android:text="@string/get_suggestion" />

 <TextView
     android:id="@+id/resultText"
     android:layout_width="wrap_content"
     android:layout_height="match_parent"
     android:layout_marginTop="20dp"
     android:text="@string/suggestion_will_appear_here"
     android:textSize="18sp"
     android:textColor="#4E342E"/>

 </LinearLayout>

